<Window x:Class="grzyClothTool.Views.OptimizeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:local="clr-namespace:grzyClothTool.Views"
        xmlns:c="clr-namespace:grzyClothTool.Controls"
        Background="{DynamicResource Brush50}"
        mc:Ignorable="d"
        Title="优化纹理" MinHeight="420" MaxHeight="420" MinWidth="690" MaxWidth="690">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="330" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="130" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>
            <GroupBox Header="当前纹理" Margin="5" Grid.Row="0" Style="{DynamicResource FixedGroupBox}">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="名称：" />
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding TextureName}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MultipleTexturesSelected}" Value="True">
                                            <Setter Property="Text" Value="{Binding SelectedTextureCount, StringFormat='已选择 {0} 个纹理'}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="压缩格式：" />
                        <TextBlock Text="{Binding TextureDetails.Compression}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="宽度：" />
                        <TextBlock Text="{Binding TextureDetails.Width}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="高度：" />
                        <TextBlock Text="{Binding TextureDetails.Height}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mipmap 数量：" />
                        <TextBlock Text="{Binding TextureDetails.MipMapCount}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            <StackPanel Grid.Row="1" Margin="0,15,0,0" >

                <c:ModernLabelCheckBox
                    Label="缩小纹理尺寸"
                    IsChecked="{Binding IsTextureDownsizeEnabled}"
                    
    
                    />
                <c:ModernLabelComboBox
                    IsEnabled="{Binding IsTextureDownsizeEnabled}"
                    Label="选择纹理尺寸"
                    SelectedItem="{Binding SelectedTextureSize}"
                    ItemsSource="{Binding AvailableTextureSizes}"
                    />
            </StackPanel>

            <StackPanel Grid.Row="2" Width="320" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTextureDownsizeEnabled}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <icons:MaterialIcon Kind="WarningBoxOutline" Width="40" Height="40" Foreground="{DynamicResource Brush950}" />
                <TextBlock Width="280" FontWeight="Medium" Foreground="{DynamicResource Brush950}" Text="在此处更改纹理尺寸会降低画质。若要保留纹理质量，应使用 3D 软件和纹理烘焙来完成。" TextWrapping="WrapWithOverflow" FontSize="12"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="2" >
            <Grid.RowDefinitions>
                <RowDefinition Height="130" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>
            <GroupBox Header="输出纹理" Margin="5" Grid.Row="0" Style="{DynamicResource FixedGroupBox}">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="名称：" />
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding TextureName}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MultipleTexturesSelected}" Value="True">
                                            <Setter Property="Text" Value="{Binding SelectedTextureCount, StringFormat='已选择 {0} 个纹理'}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="压缩格式：" />
                        <TextBlock Text="{Binding OutputTextureDetails.Compression}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="宽度：" />
                        <TextBlock Text="{Binding OutputTextureDetails.Width}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="高度：" />
                        <TextBlock Text="{Binding OutputTextureDetails.Height}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Mipmap 数量：" />
                        <TextBlock Text="{Binding OutputTextureDetails.MipMapCount}" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>
            <StackPanel Grid.Row="1" Margin="0,15,0,0">
                <c:ModernLabelCheckBox
                    IsChecked="{Binding IsTextureCompressionEnabled}"
                    Label="更改纹理压缩格式"
    
                    />
                <c:ModernLabelComboBox
                    IsEnabled="{Binding IsTextureCompressionEnabled}"
                    Label="选择压缩格式"
                    ItemsSource="{Binding AvailableCompression}"
                    SelectedItem="{Binding SelectedCompression}"
                    />
            </StackPanel>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal">
                <c:CustomButton 
                    x:Name="cancel"
                    Margin="5"
                    CornerRadius="5"
                    Height="40"
                    Width="100"
                    Label="取消"
                    MyBtnClickEvent="CancelBtn_Click"
                />
                <c:CustomButton 
                    Margin="5"
                    x:Name="build"
                    CornerRadius="5"
                    Height="40"
                    Width="180"
                    Label="优化"
                    MyBtnClickEvent="OptimizeTexture_Click"
                />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
