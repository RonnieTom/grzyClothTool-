<Window x:Class="grzyClothTool.Views.SupportPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:c="clr-namespace:grzyClothTool.Controls"
        mc:Ignorable="d"
        Title="支持开发者"
        Height="220"
        Width="460"
        ResizeMode="NoResize"
        Background="{DynamicResource Brush50}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="是否愿意赞助我？"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="{DynamicResource Brush950}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,12" />

        <TextBlock Grid.Row="1"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{DynamicResource Brush700}"
                   LineHeight="20"
                   TextAlignment="Center"
                   VerticalAlignment="Center"
                   Text="grzyClothTool 汉化版由 RONNIE_T 免费维护。若本工具对你有帮助，欢迎扫码支持，感谢你的鼓励！" />

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <c:CustomButton HorizontalAlignment="Left"
                            x:Name="cancelButton"
                            CornerRadius="5"
                            Width="150"
                            Label="取消"
                            MyBtnClickEvent="Cancel_MyBtnClickEvent" />
            <c:CustomButton HorizontalAlignment="Right"
                            x:Name="supportButton"
                            CornerRadius="5"
                            Width="150"
                            Label="支持"
                            MyBtnClickEvent="Support_MyBtnClickEvent" />
        </Grid>
    </Grid>
</Window>
