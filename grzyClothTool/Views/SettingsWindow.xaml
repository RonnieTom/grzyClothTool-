<UserControl x:Class="grzyClothTool.Views.SettingsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:grzyClothTool.Views"
             xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:helpers="clr-namespace:grzyClothTool.Helpers"
             xmlns:c="clr-namespace:grzyClothTool.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="800"
             d:Background="{DynamicResource Brush50}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>


        <Grid Grid.Row="0">
            <Button Margin="5" HorizontalAlignment="Left" VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="5" Click="BackButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Grid Width="30" Height="30">
                            <Ellipse Width="30" Height="30" Stroke="{DynamicResource Brush950}" StrokeThickness="2">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{DynamicResource Color50}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Path Stroke="{DynamicResource Brush950}" StrokeThickness="2" Fill="{DynamicResource Brush950}">
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="20,9" IsClosed="True">
                                            <LineSegment Point="20,21" />
                                            <LineSegment Point="9,15" />
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                        </Grid>
                        <TextBlock Foreground="{DynamicResource Brush950}" Margin="5,0,5,2" VerticalAlignment="Center" FontSize="16" FontWeight="Normal">返回</TextBlock>
                    </StackPanel>
                </Button>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!--<c:CustomButton Label="PATREON ACCOUNT" Padding="10" Width="200" CornerRadius="5" MyBtnClickEvent="PatreonAccount_Click" />-->

                <ToggleButton Margin="5"  IsChecked="{Binding IsDarkMode, Mode=OneWay}" Click="ThemeModeChange_Click">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Width" Value="100"/>
                            <Setter Property="Height" Value="25"/>
                            <Setter Property="Background" Value="{DynamicResource Brush500}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush950}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <!-- replaced LightbulbOn and LightbulbOff icons svg in CustomIconProvider -->
                                            <icons:MaterialIcon Kind="LightbulbOn" Width="22" Margin="3"/>
                                            <Border Width="50" Background="{TemplateBinding Background}" CornerRadius="15">
                                                <Grid>
                                                    <Ellipse x:Name="SwitchBall" Fill="{DynamicResource Brush50}" Width="11" Height="11" HorizontalAlignment="Left" Margin="5,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <icons:MaterialIcon Kind="LightbulbOff" Width="20" Margin="3"/>
                                        </StackPanel>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ThicknessAnimation Storyboard.TargetName="SwitchBall" Storyboard.TargetProperty="Margin" To="33,0,5,0" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <ThicknessAnimation Storyboard.TargetName="SwitchBall" Storyboard.TargetProperty="Margin" To="5,0,33,0" Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StackPanel>
        </Grid>


        <Grid Grid.Row="1">
            <GroupBox Grid.ColumnSpan="2" Style="{DynamicResource FixedGroupBox}" Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="5" Grid.Column="0">

                            <GroupBox Margin="0,5" Height="120" Style="{DynamicResource FixedGroupBox}">
                                <GroupBox.Header>
                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Brush950}" Text="可绘制模型面数上限" />
                                </GroupBox.Header>
                                <Grid Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Padding="5,2,5,5" FontStyle="Italic" FontWeight="Normal" Foreground="{DynamicResource Brush500}" Grid.Row="0" Grid.ColumnSpan="3" TextWrapping="Wrap">设置可绘制模型的面数上限，超出此数值时将显示警告</TextBlock>
                                    <c:SettingsLabelTextBox Grid.Row="1" Grid.Column="0" Label="高 LOD" LabelFontSize="12" Text="{Binding Path=Instance.PolygonLimitHigh, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" ButtonVisible="False" />
                                    <c:SettingsLabelTextBox Grid.Row="1" Grid.Column="1" Label="中 LOD" LabelFontSize="12" Text="{Binding Path=Instance.PolygonLimitMed, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" ButtonVisible="False" />
                                    <c:SettingsLabelTextBox Grid.Row="1" Grid.Column="2" Label="低 LOD" LabelFontSize="12" Text="{Binding Path=Instance.PolygonLimitLow, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" ButtonVisible="False" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Margin="0,5" Height="140" Style="{DynamicResource FixedGroupBox}">
                                <GroupBox.Header>
                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Brush950}" Text="纹理分辨率上限" />
                                </GroupBox.Header>
                                <Grid Margin="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto" />
                                        <RowDefinition Height="auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Padding="5,2,5,5" FontStyle="Italic" FontWeight="Normal" Foreground="{DynamicResource Brush500}" Grid.Row="0" Grid.ColumnSpan="3" TextWrapping="Wrap">设置各类型纹理的最大分辨率。若宽度或高度超出上限，将显示警告</TextBlock>
                                    <c:SettingsLabelComboBox Grid.Row="1" Grid.Column="0" Label="漫反射" LabelFontSize="12" ItemsSource="{Binding TextureResolutionOptions}" SelectedItem="{Binding Path=Instance.TextureResolutionLimitDiffuse, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />
                                    <c:SettingsLabelComboBox Grid.Row="1" Grid.Column="1" Label="法线" LabelFontSize="12" ItemsSource="{Binding TextureResolutionOptions}" SelectedItem="{Binding Path=Instance.TextureResolutionLimitNormal, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />
                                    <c:SettingsLabelComboBox Grid.Row="1" Grid.Column="2" Label="高光" LabelFontSize="12" ItemsSource="{Binding TextureResolutionOptions}" SelectedItem="{Binding Path=Instance.TextureResolutionLimitSpecular, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                        <StackPanel Margin="5" Grid.Column="1">
                            <GroupBox Margin="0,5" Height="380" Style="{DynamicResource FixedGroupBox}">
                                <GroupBox.Header>
                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Brush950}" Text="常规设置" />
                                </GroupBox.Header>

                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel Margin="0">
                                        <c:SettingsLabelTextBox
                                            Margin="5"
                                            Label="主项目文件夹"
                                            Text="{Binding MainProjectsFolder, Mode=TwoWay}"
                                            Description="存放所有服装项目的主文件夹"
                                            Title="选择主项目文件夹"
                                            ButtonClick="MainProjectsFolder_Click" />

                                        <c:SettingsLabelTextBox
                                            Margin="5"
                                            Label="当前 GTA V 路径"
                                            Text="{Binding GTAVPath, Mode=OneWay}"
                                            Description="3D 预览需要设置 GTA V 路径"
                                            Title="选择 GTA V 路径"
                                            ButtonClick="GTAVPath_Click" />

                                        <c:SettingsLabelCheckBox
                                            Margin="5"
                                            Label="显示可绘制模型路径"
                                            Text="启用后将显示所选可绘制模型的使用路径"
                                            IsChecked="{Binding Path=Instance.DisplaySelectedDrawablePath, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />

                                        <c:SettingsLabelCheckBox
                                            Margin="5"
                                            Label="自动删除可绘制模型文件"
                                            Text="启用后，从插件中删除可绘制模型时将自动从系统中移除关联文件"
                                            DisplayWarning="警告：此功能将修改并删除您电脑上的文件。任何已删除的文件无法恢复。&#x0a;&#x0a;确定要启用吗？"
                                            IsChecked="{Binding Path=Instance.AutoDeleteFiles, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />

                                        <c:SettingsLabelCheckBox
                                            Margin="5"
                                            Label="标记新建可绘制模型"
                                            Text="启用后，新建的可绘制模型将以黄点标记"
                                            IsChecked="{Binding Path=Instance.MarkNewDrawables, Source={x:Static helpers:SettingsHelper.Instance}, Mode=TwoWay}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </GroupBox>

                        </StackPanel>

                    </Grid>
                </ScrollViewer>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
